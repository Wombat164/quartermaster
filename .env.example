# Quartermaster configuration. Copy to .env (gitignored) and fill in.
# All variables are prefixed QM_. Secrets come from your secret store (e.g. Bitwarden),
# injected via env -- NEVER commit real secrets. See SECURITY.md.

# Fail-safe: never act for real unless explicitly False.
QM_DRY_RUN=true

# Gitignored runtime state (db, backups).
QM_DATA_DIR=data

# structlog level (DEBUG/INFO/WARNING/ERROR).
QM_LOG_LEVEL=INFO

# Listing source: file | stdin | mbox | imap | gmail.
QM_MAIL_SOURCE=file

# file/mbox source: a dir of .eml/.txt, or an .mbox file.
QM_MAIL_PATH=data/alerts

# IMAP host, e.g. imap.gmail.com (imap source).
QM_IMAP_HOST=

# IMAP SSL port.
QM_IMAP_PORT=993

# IMAP username / email address.
QM_IMAP_USER=

# IMAP folder/label to read.
QM_IMAP_FOLDER=INBOX

# Gmail label to read (gmail source).
QM_GMAIL_LABEL=

# Gmail OAuth token cache (gitignored).
QM_GMAIL_TOKEN_PATH=data/gmail_token.json

# Gmail OAuth client secret (gitignored).
QM_GMAIL_CLIENT_SECRET_PATH=data/gmail_client_secret.json

# SerpApi key (Phase-1 Google-Shopping price baseline).
QM_SERPAPI_API_KEY=

# Anthropic API key (LLM listing extraction).
QM_ANTHROPIC_API_KEY=

# healthchecks.io dead-man's-switch ping URL.
QM_HEALTHCHECKS_PING_URL=

# IMAP app-password (from your secret store; never committed).
QM_IMAP_PASSWORD=
