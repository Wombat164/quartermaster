# Quartermaster configuration. Copy to .env (gitignored) and fill in.
# All variables are prefixed QM_. Secrets come from your secret store (e.g. Bitwarden),
# injected via env -- NEVER commit real secrets. See SECURITY.md.

# Fail-safe: never act for real unless explicitly False.
QM_DRY_RUN=true

# Gitignored runtime state (db, backups).
QM_DATA_DIR=data

# structlog level (DEBUG/INFO/WARNING/ERROR).
QM_LOG_LEVEL=INFO

# SerpApi key (Phase-1 Google-Shopping price baseline).
QM_SERPAPI_API_KEY=

# Anthropic API key (LLM listing extraction).
QM_ANTHROPIC_API_KEY=

# healthchecks.io dead-man's-switch ping URL.
QM_HEALTHCHECKS_PING_URL=
